# Inference
INFERENCE_RUNTIME=local
DEMUCS_MODEL=htdemucs_6s
DEMUCS_DEVICE=mps
BASIC_PITCH_ONSET_THRESHOLD=0.5
BASIC_PITCH_FRAME_THRESHOLD=0.3
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.7
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

# Storage
MUSICAI_DATA_DIR=./data
MUSICAI_DATABASE_URL=sqlite+aiosqlite:///./data/musicai.db

# API
MUSICAI_API_HOST=0.0.0.0
MUSICAI_API_PORT=8000
MUSICAI_WEB_URL=http://localhost:3000

# YouTube (local-only feature flag)
YOUTUBE_INGEST_ENABLED=true

# Cloud fallback (post-MVP)
# INFERENCE_RUNTIME=cloud
# REPLICATE_API_TOKEN=
