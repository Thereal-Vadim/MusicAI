{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://musicai.local/schemas/tab-document/v1.json",
  "title": "TabDocument",
  "type": "object",
  "required": ["version", "meta", "tracks"],
  "properties": {
    "version": { "const": "1" },
    "job_id": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["bpm", "tuning", "source"],
      "properties": {
        "bpm": { "type": "number" },
        "key": { "type": "string" },
        "mode": { "type": "string" },
        "tuning": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 6,
          "maxItems": 6
        },
        "source": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["upload", "youtube"] },
            "url": { "type": "string" },
            "youtube_id": { "type": "string" },
            "filename": { "type": "string" }
          }
        },
        "pipeline_version": { "type": "string" },
        "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["instrument", "measures"],
        "properties": {
          "instrument": { "const": "guitar" },
          "measures": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["start_ms", "notes"],
              "properties": {
                "index": { "type": "integer" },
                "start_ms": { "type": "number" },
                "confidence": { "type": "number" },
                "chord": { "type": "string" },
                "notes": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/note" }
                }
              }
            }
          }
        }
      }
    },
    "edit_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "note_id": { "type": "string" },
          "field": { "type": "string" },
          "old_value": {},
          "new_value": {}
        }
      }
    }
  },
  "$defs": {
    "note": {
      "type": "object",
      "required": ["id", "pitch", "start_ms", "duration_ms", "string", "fret"],
      "properties": {
        "id": { "type": "string" },
        "pitch": { "type": "string" },
        "original_pitch": { "type": "string" },
        "start_ms": { "type": "number" },
        "duration_ms": { "type": "number" },
        "string": { "type": "integer", "minimum": 1, "maximum": 6 },
        "fret": { "type": "integer", "minimum": 0, "maximum": 24 },
        "pitch_midi": { "type": "integer" },
        "confidence": {
          "type": "object",
          "properties": {
            "audio": { "type": "number" },
            "vision": { "type": "number" },
            "judge": { "type": "number" },
            "overall": { "type": "number" }
          }
        },
        "sources": {
          "type": "object",
          "properties": {
            "audio_fret": { "type": "integer" },
            "vision_fret": { "type": "integer" },
            "theory_fret": { "type": "integer" }
          }
        },
        "judge": {
          "type": "object",
          "properties": {
            "in_scale": { "type": "boolean" },
            "in_chord": { "type": "boolean" },
            "snapped": { "type": "boolean" },
            "snap_reason": { "type": "string" },
            "flags": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "flags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
